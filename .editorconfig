# EditorConfig — consistent whitespace/encoding across editors.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Why 2 spaces everywhere: the repo is mostly YAML, JSON, FSH, and Markdown —
# all conventionally 2-space indented; one rule avoids per-language surprises.

[*.md]
# Why: Markdown uses two trailing spaces as a hard line break — trimming them
# would silently change rendering.
trim_trailing_whitespace = false

[Makefile]
# Why: make requires literal tabs in recipes.
indent_style = tab
